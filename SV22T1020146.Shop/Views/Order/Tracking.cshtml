@{
    ViewData["Title"] = "Theo dõi đơn hàng";
}

<div class="card shadow-sm border-0 rounded-4 p-5">
    <div class="text-center mb-5">
        <h3 class="fw-bold">Trạng thái đơn hàng: <span class="text-primary">#ORD-1002</span></h3>
        <p class="text-muted">Đặt ngày 28 tháng 03, 2026</p>
    </div>

    <div class="position-relative mb-5 py-4">
        <div class="progress" style="height: 4px;">
            <div class="progress-bar" role="progressbar" style="width: 66%;"></div>
        </div>
        <div class="d-flex justify-content-between position-absolute w-100 top-50 translate-middle-y">
            <div class="text-center bg-white">
                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto shadow" style="width:40px; height:40px;">
                    <i class="fa fa-check"></i>
                </div>
                <p class="small fw-bold mt-2 mb-0">Đã xác nhận</p>
            </div>
            <div class="text-center bg-white">
                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto shadow" style="width:40px; height:40px;">
                    <i class="fa fa-box"></i>
                </div>
                <p class="small fw-bold mt-2 mb-0">Đang đóng gói</p>
            </div>
            <div class="text-center bg-white">
                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto shadow" style="width:40px; height:40px;">
                    <i class="fa fa-truck"></i>
                </div>
                <p class="small fw-bold mt-2 mb-0">Đang vận chuyển</p>
            </div>
            <div class="text-center bg-white text-muted">
                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto" style="width:40px; height:40px;">
                    <i class="fa fa-home"></i>
                </div>
                <p class="small mt-2 mb-0">Giao thành công</p>
            </div>
        </div>
    </div>

    <div class="bg-light rounded-4 p-4 mt-4">
        <div class="row">
            <div class="col-md-6 border-end">
                <h6 class="fw-bold text-muted mb-3">ĐỊA CHỈ NHẬN HÀNG</h6>
                <p class="mb-1 fw-bold">Trần Quang Hiếu</p>
                <p class="mb-1 small text-muted">0905 123 456</p>
                <p class="mb-0 small text-muted">77 Nguyễn Huệ, Phường Vĩnh Ninh, TP Huế</p>
            </div>
            <div class="col-md-6 ps-4">
                <h6 class="fw-bold text-muted mb-3">THÔNG TIN GIAO HÀNG</h6>
                <p class="mb-1 small">Giao bởi: <span class="fw-bold">Giao Hàng Nhanh</span></p>
                <p class="mb-0 small">Dự kiến nhận: <span class="fw-bold">30/03/2026</span></p>
            </div>
        </div>
    </div>
</div>