@model SV22T1020146.Shop.Models.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký tài khoản mới";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-9 col-lg-10">
            <div class="card register-card shadow-lg border-0">
                <div class="card-body p-4 p-md-5">

                    <div class="text-center mb-5">
                        <div class="d-inline-block bg-primary-subtle text-primary rounded-circle p-4 mb-3">
                            <i class="fa-solid fa-user-plus fs-1"></i>
                        </div>
                        <h2 class="fw-bold text-dark">Tham gia cùng NDH</h2>
                        <p class="text-muted small">Khám phá trải nghiệm mua sắm tuyệt vời và ưu đãi hấp dẫn</p>
                    </div>

                    <form asp-action="Register" method="post">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger alert-dismissible fade show rounded-4 small mb-4" role="alert">
                                <i class="fa-solid fa-circle-exclamation me-2"></i>
                                <span>Vui lòng kiểm tra lại các thông tin bên dưới.</span>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        <div class="row g-4">
                            <div class="col-md-6 border-end-md">
                                <h5 class="section-title small text-uppercase">Thông tin cá nhân</h5>

                                <div class="mb-4">
                                    <label class="form-label small fw-bold text-muted ps-2">Họ và tên</label>
                                    <div class="input-group-custom">
                                        <i class="fa-solid fa-signature"></i>
                                        <input asp-for="CustomerName" class="form-control" placeholder="">
                                    </div>
                                    <span asp-validation-for="CustomerName" class="text-danger validation-msg"></span>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label small fw-bold text-muted ps-2">Số điện thoại</label>
                                    <div class="input-group-custom">
                                        <i class="fa-solid fa-phone"></i>
                                        <input asp-for="Phone" class="form-control" placeholder="">
                                    </div>
                                    <span asp-validation-for="Phone" class="text-danger validation-msg"></span>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label small fw-bold text-muted ps-2">Tỉnh / Thành phố</label>
                                    <div class="input-group-custom">
                                        <i class="fa-solid fa-map-location-dot"></i>
                                        <select asp-for="Province" class="form-select">
                                            <option value="">-- Chọn tỉnh/thành --</option>
                                            @foreach (var p in ViewBag.Provinces)
                                            {
                                                <option value="@p.ProvinceName">@p.ProvinceName</option>
                                            }
                                        </select>
                                    </div>
                                    <span asp-validation-for="Province" class="text-danger validation-msg"></span>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label small fw-bold text-muted ps-2">Địa chỉ chi tiết</label>
                                    <div class="input-group-custom">
                                        <i class="fa-solid fa-house-user"></i>
                                        <input asp-for="Address" class="form-control" placeholder="">
                                    </div>
                                    <span asp-validation-for="Address" class="text-danger validation-msg"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <h5 class="section-title small text-uppercase">Thông tin tài khoản</h5>

                                <div class="mb-4">
                                    <label class="form-label small fw-bold text-muted ps-2">Email đăng nhập</label>
                                    <div class="input-group-custom">
                                        <i class="fa-solid fa-envelope"></i>
                                        <input asp-for="Email" class="form-control" placeholder="">
                                    </div>
                                    <span asp-validation-for="Email" class="text-danger validation-msg"></span>
                                </div>

                                <div class="mb-4 position-relative">
                                    <label class="form-label small fw-bold text-muted ps-2">Mật khẩu</label>
                                    <div class="input-group-custom">
                                        <i class="fa-solid fa-lock"></i>
                                        <input asp-for="Password" type="password" class="form-control" id="regPass" placeholder="">
                                        <i class="fa-solid fa-eye-slash small ms-auto cursor-pointer text-muted" onclick="togglePass('regPass', this)"></i>
                                    </div>
                                    <span asp-validation-for="Password" class="text-danger validation-msg"></span>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label small fw-bold text-muted ps-2">Xác nhận mật khẩu</label>
                                    <div class="input-group-custom">
                                        <i class="fa-solid fa-shield-check"></i>
                                        <input asp-for="ConfirmPassword" type="password" class="form-control" id="confirmPass" placeholder="">
                                    </div>
                                    <span asp-validation-for="ConfirmPassword" class="text-danger validation-msg"></span>
                                </div>

                                <div class="mb-4 ps-2">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="terms" required checked>
                                        <label class="form-check-label small text-muted" for="terms">
                                            Tôi đồng ý với các <a href="#" class="text-primary fw-bold text-decoration-none">Điều khoản</a> của NDH Shop.
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 text-center">
                            <button type="submit" class="btn btn-primary btn-register px-5 py-3 rounded-pill fw-bold text-white w-100 shadow">
                                <i class="fa-solid fa-rocket me-2"></i> HOÀN TẤT ĐĂNG KÝ
                            </button>

                            <p class="mt-4 text-muted small">
                                Đã có tài khoản?
                                <a asp-action="Login" class="text-primary fw-bold text-decoration-none ms-1">
                                    Đăng nhập ngay <i class="fa-solid fa-arrow-right-long ms-1 small"></i>
                                </a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePass(id, icon) {
            const input = document.getElementById(id);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace("fa-eye-slash", "fa-eye");
            } else {
                input.type = "password";
                icon.classList.replace("fa-eye", "fa-eye-slash");
            }
        }
    </script>
}

@section Styles {
    <style>
        /* Hiệu ứng trượt lên khi load trang */
        @@keyframes slideInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .register-card {
            border-radius: 20px;
            animation: slideInUp 0.6s ease-out;
        }

        .section-title {
            border-left: 5px solid #0d6efd;
            padding-left: 15px;
            color: #333;
            margin-bottom: 25px;
            font-weight: 700;
        }

        .input-group-custom {
            border: 1px solid #e0e0e0;
            border-radius: 50px;
            background: #f8f9fa;
            padding: 5px 15px;
            transition: all 0.3s;
            display: flex;
            align-items: center;
        }

            .input-group-custom:focus-within {
                background: #fff;
                border-color: #0d6efd;
                box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
            }

            .input-group-custom input, .input-group-custom select {
                border: none !important;
                background: transparent !important;
                box-shadow: none !important;
                padding: 10px 12px;
                font-size: 0.95rem;
            }

            .input-group-custom i {
                color: #6c757d;
                width: 20px;
                text-align: center;
            }

        .btn-register {
            background: linear-gradient(45deg, #0d6efd, #00d2ff);
            border: none;
            letter-spacing: 1px;
            transition: all 0.3s;
        }

            .btn-register:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(13, 110, 253, 0.3);
                color: white;
            }

        .validation-msg {
            font-size: 0.75rem;
            margin-left: 20px;
            display: block;
            margin-top: 4px;
        }
    </style>
}