@model SV22T1020146.Shop.Models.ProfileViewModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-11 col-xl-10">
            <div class="card main-profile-card shadow-sm border-0 overflow-hidden">
                <div class="row g-0">
                    <div class="col-md-4 profile-sidebar p-5 text-white text-center">
                        <div class="position-relative d-inline-block mb-4">
                            <div class="avatar-circle shadow-lg">
                                @(string.IsNullOrEmpty(Model.CustomerName) ? "U" : Model.CustomerName.Substring(0, 1).ToUpper())
                            </div>
                            <div class="status-indicator shadow"></div>
                        </div>

                        <h4 class="fw-bold mb-1">@Model.CustomerName</h4>
                        <p class="text-white-50 small mb-4">Thông tin thành viên</p>

                        <div class="nav flex-column nav-pills text-start mt-4 custom-nav">
                            <a class="nav-link active shadow-sm mb-2" href="#"><i class="fa-solid fa-user-pen me-2"></i> Hồ sơ cá nhân</a>
                        </div>
                    </div>

                    <div class="col-md-8 p-4 p-md-5 bg-white shadow-inner">
                        <div class="header-content mb-5 d-flex align-items-center justify-content-between">
                            <div>
                                <h2 class="fw-extrabold text-dark mb-1">Thiết lập tài khoản</h2>
                                <p class="text-muted small m-0">Quản lý thông tin định danh và liên lạc của bạn.</p>
                            </div>
                            <div class="icon-box shadow-sm text-primary">
                                <i class="fa-solid fa-user-gear fs-4"></i>
                            </div>
                        </div>

                        @if (ViewBag.Message != null)
                        {
                            <div class="alert alert-modern alert-success alert-dismissible fade show mb-4" role="alert">
                                <div class="d-flex align-items-center">
                                    <div class="alert-icon-circle me-3">
                                        <i class="fa-solid fa-check"></i>
                                    </div>
                                    <div>@ViewBag.Message</div>
                                </div>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        <form asp-action="Profile" method="post">
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <div class="form-group-custom">
                                        <label class="form-label-custom">Họ và tên khách hàng</label>
                                        <div class="input-with-icon">
                                            <i class="fa-solid fa-signature"></i>
                                            <input asp-for="CustomerName" class="form-control-modern" placeholder="Nhập họ tên..." />
                                        </div>
                                        <span asp-validation-for="CustomerName" class="text-danger x-small mt-1 d-block"></span>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group-custom">
                                        <label class="form-label-custom">Tên người liên hệ</label>
                                        <div class="input-with-icon">
                                            <i class="fa-solid fa-user-tag"></i>
                                            <input asp-for="ContactName" class="form-control-modern" />
                                        </div>
                                        <span asp-validation-for="ContactName" class="text-danger x-small mt-1 d-block"></span>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group-custom">
                                        <label class="form-label-custom">Số điện thoại di động</label>
                                        <div class="input-with-icon">
                                            <i class="fa-solid fa-mobile-screen-button"></i>
                                            <input asp-for="Phone" class="form-control-modern" />
                                        </div>
                                        <span asp-validation-for="Phone" class="text-danger x-small mt-1 d-block"></span>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group-custom">
                                        <label class="form-label-custom">Địa chỉ Email liên lạc</label>
                                        <div class="input-with-icon">
                                            <i class="fa-solid fa-envelope"></i>
                                            <input asp-for="Email" class="form-control-modern" placeholder="example@mail.com" />
                                        </div>
                                        <span asp-validation-for="Email" class="text-danger x-small mt-1 d-block"></span>
                                    </div>
                                </div>

                                <div class="col-md-12">
                                    <div class="form-group-custom">
                                        <label class="form-label-custom">Tỉnh / Thành phố cư trú</label>
                                        <div class="input-with-icon">
                                            <i class="fa-solid fa-location-dot"></i>
                                            <select asp-for="Province" asp-items="ViewBag.Provinces" class="form-select-modern"></select>
                                        </div>
                                        <span asp-validation-for="Province" class="text-danger x-small mt-1 d-block"></span>
                                    </div>
                                </div>

                                <div class="col-md-12">
                                    <div class="form-group-custom">
                                        <label class="form-label-custom">Địa chỉ nhận hàng chi tiết</label>
                                        <div class="input-with-icon">
                                            <i class="fa-solid fa-map-marked-alt"></i>
                                            <input asp-for="Address" class="form-control-modern" placeholder="Số nhà, tên đường..." />
                                        </div>
                                        <span asp-validation-for="Address" class="text-danger x-small mt-1 d-block"></span>
                                    </div>
                                </div>

                                <div class="col-12 mt-5 pt-3">
                                    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-3">
                                        <a asp-controller="Home" asp-action="Index" class="btn btn-link text-decoration-none text-muted order-2 order-sm-1">
                                            <i class="fa-solid fa-chevron-left me-1 small"></i> Quay lại
                                        </a>
                                        <button type="submit" class="btn btn-save-profile px-5 py-2 fw-bold order-1 order-sm-2 text-white">
                                            CẬP NHẬT HỒ SƠ <i class="fa-solid fa-check-double ms-2"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@section Styles {
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #0d6efd 0%, #003a8c 100%);
            --soft-bg: #f8fafc;
            --border-color: #f1f5f9;
        }

        body {
            background-color: #f1f3f6;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }

        .fw-extrabold {
            font-weight: 800;
        }

        .x-small {
            font-size: 0.75rem;
        }

        .main-profile-card {
            border-radius: 28px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.06) !important;
        }

        .profile-sidebar {
            background: var(--primary-gradient);
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .avatar-circle {
            width: 120px;
            height: 120px;
            background: rgba(255, 255, 255, 0.12);
            backdrop-filter: blur(12px);
            border: 4px solid rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            font-weight: 800;
            color: white;
            margin: 0 auto;
        }

        .status-indicator {
            position: absolute;
            bottom: 8px;
            right: calc(50% - 55px);
            width: 24px;
            height: 24px;
            background: #10b981;
            border: 4px solid #0b4ab1;
            border-radius: 50%;
        }

        .custom-nav .nav-link {
            border-radius: 14px;
            padding: 12px 20px;
            transition: 0.3s;
            font-weight: 500;
            color: rgba(255,255,255,0.7);
        }

            .custom-nav .nav-link.active {
                background: white !important;
                color: #0d6efd !important;
            }

        .icon-box {
            width: 52px;
            height: 52px;
            background: #eff6ff;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .form-label-custom {
            font-weight: 700;
            font-size: 0.75rem;
            color: #64748b;
            margin-bottom: 8px;
            display: block;
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }

        .input-with-icon {
            position: relative;
        }

            .input-with-icon i {
                position: absolute;
                left: 18px;
                top: 50%;
                transform: translateY(-50%);
                color: #94a3b8;
                transition: 0.3s;
            }

        .form-control-modern, .form-select-modern {
            width: 100%;
            padding: 12px 15px 12px 52px;
            border: 2px solid var(--border-color);
            border-radius: 16px;
            transition: all 0.3s ease;
            background-color: #f8fafc;
            font-size: 0.95rem;
            font-weight: 500;
        }

            .form-control-modern:focus, .form-select-modern:focus {
                border-color: #3b82f6;
                background-color: white;
                box-shadow: 0 0 0 5px rgba(59, 130, 246, 0.08);
                outline: none;
            }

                .form-control-modern:focus + i {
                    color: #3b82f6;
                }

        .btn-save-profile {
            background: var(--primary-gradient);
            border: none;
            border-radius: 16px;
            transition: all 0.4s;
            box-shadow: 0 10px 25px rgba(13, 110, 253, 0.2);
        }

            .btn-save-profile:hover {
                transform: translateY(-2px);
                box-shadow: 0 15px 30px rgba(13, 110, 253, 0.3);
                filter: brightness(1.1);
            }

        .alert-modern {
            border-radius: 18px;
            border: none;
            background: #f0fdf4;
            color: #166534;
            border-left: 6px solid #22c55e;
        }

        .alert-icon-circle {
            width: 34px;
            height: 34px;
            background: #22c55e;
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>
}