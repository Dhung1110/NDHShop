@model SV22T1020146.Shop.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card auth-card shadow-lg rounded-4 overflow-hidden">

                <div class="card-body p-4 p-lg-5">
                    <div class="text-center mb-5">
                        <div class="auth-icon-box rounded-circle d-flex align-items-center justify-content-center mb-4">
                            <i class="fa-solid fa-lock-open fs-2"></i>
                        </div>
                        <h3 class="fw-bold">Cập nhật mật khẩu</h3>
                        <p class="text-muted small">Đảm bảo mật khẩu của bạn có ít nhất 6 ký tự để bảo mật an toàn.</p>
                    </div>

                    <form asp-action="ChangePassword" method="post">
                        @if (ViewBag.Message != null)
                        {
                            <div class="alert alert-success alert-dismissible fade show text-center mb-4 rounded-3" role="alert">
                                <i class="fa-solid fa-circle-check me-2"></i> @ViewBag.Message
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-dark ps-2">Mật khẩu hiện tại</label>
                            <div class="input-group-custom d-flex align-items-center">
                                <i class="fa-solid fa-key text-muted"></i>
                                <input asp-for="OldPassword" type="password" class="form-control" placeholder="Nhập mật khẩu cũ" id="oldPass" />
                                <i class="fa-solid fa-eye toggle-password" onclick="togglePass('oldPass', this)"></i>
                            </div>
                            <span asp-validation-for="OldPassword" class="text-danger small ps-2"></span>
                        </div>

                        <hr class="my-4 opacity-25">

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-dark ps-2">Mật khẩu mới</label>
                            <div class="input-group-custom d-flex align-items-center">
                                <i class="fa-solid fa-shield-heart text-muted"></i>
                                <input asp-for="NewPassword" type="password" class="form-control" placeholder="Mật khẩu mới" id="newPass" />
                                <i class="fa-solid fa-eye toggle-password" onclick="togglePass('newPass', this)"></i>
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger small ps-2"></span>
                        </div>

                        <div class="mb-5">
                            <label class="form-label small fw-bold text-dark ps-2">Xác nhận lại</label>
                            <div class="input-group-custom d-flex align-items-center">
                                <i class="fa-solid fa-circle-check text-muted"></i>
                                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Nhập lại mật khẩu mới" id="confirmPass" />
                                <i class="fa-solid fa-eye toggle-password" onclick="togglePass('confirmPass', this)"></i>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small ps-2"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-gradient w-100 py-3 rounded-pill fw-bold text-white shadow-sm mb-4">
                            LƯU THAY ĐỔI
                        </button>

                        <div class="text-center">
                            <a asp-controller="Home" asp-action="Index" class="text-decoration-none small text-muted hover-primary">
                                <i class="fa-solid fa-house me-1"></i> Quay lại trang chủ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Hàm ẩn hiện mật khẩu
        function togglePass(inputId, icon) {
            const input = document.getElementById(inputId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace("fa-eye", "fa-eye-slash");
            } else {
                input.type = "password";
                icon.classList.replace("fa-eye-slash", "fa-eye");
            }
        }
    </script>
}
@section Styles {
    <style>
        .auth-card {
            border: none;
            transition: all 0.3s ease;
        }

        .auth-icon-box {
            background: rgba(13, 110, 253, 0.1);
            color: #0d6efd;
            width: 80px;
            height: 80px;
            margin: 0 auto;
        }

        .input-group-custom {
            border: 1px solid #e0e0e0;
            border-radius: 50px;
            background: #f8f9fa;
            padding: 5px 15px;
            transition: all 0.3s;
        }

            .input-group-custom:focus-within {
                background: #fff;
                border-color: #0d6efd;
                box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
            }

            .input-group-custom input {
                border: none !important;
                background: transparent !important;
                box-shadow: none !important;
                padding: 10px 12px;
            }

        .btn-gradient {
            background: linear-gradient(45deg, #0d6efd, #00d2ff);
            border: none;
            letter-spacing: 1px;
            transition: transform 0.2s, box-shadow 0.2s;
        }

            .btn-gradient:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(13, 110, 253, 0.3);
            }

        .toggle-password {
            cursor: pointer;
            color: #6c757d;
        }

            .toggle-password:hover {
                color: #0d6efd;
            }
    </style>
}