
@model PaginationSearchInput

@{
    ViewBag.Title = "Quản lý Loại hàng";
}
@section PageToolBar {
    <a href="~/Category/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}
<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch"
              method="get"
              action="~/Category/Search"
              data-target="searchResult"
              onsubmit="paginationSearch(event, this, 1)">

            <div class="input-group">

                <input type="hidden" asp-for="PageSize" />
                <input type="text" asp-for="SearchValue"
                       class="form-control"
                       placeholder="Tên loại hàng..."
                       autofocus />

                <button class="btn btn-info">
                    <i class="bi bi-search"></i>
                </button>

            </div>
        </form>
    </div>
</div>
<div id="searchResult"></div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
    });
</script>