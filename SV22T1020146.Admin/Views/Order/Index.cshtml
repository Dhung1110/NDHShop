@model OrderSearchInput
@{
    ViewBag.Title = "Quản lý Đơn hàng";
}

@section PageToolBar {
    <a href="~/Order/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Lập đơn hàng mới
    </a>
}

<div class="card mb-3">
    <div class="card-body">

        <form id="formSearch"
              method="get"
              action="~/Order/Search"
              data-target="searchResult"
              onsubmit="paginationSearch(event, this, 1)">

            <!-- QUAN TRỌNG -->
            <input type="hidden" asp-for="PageSize" />

            <div class="row g-2">

                <!-- STATUS -->
                <div class="col-md-3">
                    <label>Trạng thái</label>
                    <select name="Status" class="form-select">

                        <option value="0">-- Tất cả --</option>

                        <option value="1" selected="@(Model.Status == OrderStatusEnum.New)">Đang chờ duyệt</option>
                        <option value="2" selected="@(Model.Status == OrderStatusEnum.Accepted)">Đã duyệt</option>
                        <option value="3" selected="@(Model.Status == OrderStatusEnum.Shipping)">Đang giao</option>
                        <option value="4" selected="@(Model.Status == OrderStatusEnum.Completed)">Hoàn tất</option>

                        <option value="-1" selected="@(Model.Status == OrderStatusEnum.Cancelled)">Bị hủy</option>
                        <option value="-2" selected="@(Model.Status == OrderStatusEnum.Rejected)">Bị từ chối</option>

                    </select>
                </div>

                <!-- DATE -->
                <div class="col-md-4">
                    <label>Thời gian</label>
                    <div class="input-group">

                        <input type="date"
                               name="DateFrom"
                               value="@(Model.DateFrom?.ToString("yyyy-MM-dd"))"
                               class="form-control" />

                        <span class="input-group-text">-</span>

                        <input type="date"
                               name="DateTo"
                               value="@(Model.DateTo?.ToString("yyyy-MM-dd"))"
                               class="form-control" />

                    </div>
                </div>

                <!-- SEARCH -->
                <div class="col-md-5">
                    <label>Tên khách hàng</label>

                    <div class="input-group">

                        <input type="text"
                               name="SearchValue"
                               value="@Model.SearchValue"
                               class="form-control"
                               placeholder="Tên khách hàng..." />

                        <button class="btn btn-info">
                            <i class="bi bi-search"></i>
                        </button>

                    </div>
                </div>

            </div>
        </form>

    </div>
</div>

<div id="searchResult"></div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
    });
</script>