@model SV22T1020146.Models.Sales.OrderViewInfo

@{
    var details = ViewBag.Details as List<SV22T1020146.Models.Sales.OrderDetailViewInfo>;
    decimal sum = 0;
    int i = 1;
    ViewBag.Title = "Chi tiết đơn hàng";

    string statusText = Model.Status switch
    {
        OrderStatusEnum.Rejected => "Đơn hàng bị từ chối",
        OrderStatusEnum.Cancelled => "Đơn hàng đã bị hủy",
        OrderStatusEnum.New => "Đơn hàng vừa tạo",
        OrderStatusEnum.Accepted => "Đơn hàng đã được duyệt",
        OrderStatusEnum.Shipping => "Đơn hàng đang được vận chuyển",
        OrderStatusEnum.Completed => "Đơn hàng đã hoàn tất",
        _ => "Không xác định"
    };

    bool canShip = Model.Status == OrderStatusEnum.Accepted;
    bool canFinish = Model.Status == OrderStatusEnum.Shipping;
    bool canCancel = Model.Status == OrderStatusEnum.New || Model.Status == OrderStatusEnum.Accepted;
    bool canReject = Model.Status == OrderStatusEnum.New;
}

@section PageToolBar {
    <div class="btn-group">
        @if (Model.Status == OrderStatusEnum.Cancelled
            || Model.Status == OrderStatusEnum.Rejected
            || Model.Status == OrderStatusEnum.Completed)
        {
            <button class="btn btn-secondary dropdown-toggle" disabled>
                <i class="bi bi-check-circle"></i> Đã xử lý
            </button>
        }
        else
        {
            <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown">
                <i class="bi bi-gear me-1"></i> Xử lý đơn hàng
            </button>

            <ul class="dropdown-menu">
                @if (Model.Status == OrderStatusEnum.New)
                {
                    <li>
                        <button class="dropdown-item" data-bs-toggle="modal" data-bs-target="#acceptModal">
                            Duyệt đơn hàng
                        </button>
                    </li>
                    <li>
                        <button class="dropdown-item text-danger" data-bs-toggle="modal" data-bs-target="#rejectModal">
                            Từ chối đơn hàng
                        </button>
                    </li>
                }
                else if (Model.Status == OrderStatusEnum.Accepted)
                {
                    <li>
                        <button class="dropdown-item" data-bs-toggle="modal" data-bs-target="#shippingModal">
                            Chuyển giao hàng
                        </button>
                    </li>
                    @if (canCancel)
                    {
                        <li>
                            <button class="dropdown-item text-warning" data-bs-toggle="modal" data-bs-target="#cancelModal">
                                Hủy đơn hàng
                            </button>
                        </li>
                    }
                }
                else if (Model.Status == OrderStatusEnum.Shipping)
                {
                    <li>
                        <button class="dropdown-item" data-bs-toggle="modal" data-bs-target="#finishModal">
                            Hoàn tất đơn hàng
                        </button>
                    </li>
                }
            </ul>
        }
    </div>

    @if (Model.Status == OrderStatusEnum.New)
    {
        <a href="~/Order/Delete/@Model.OrderID" class="btn btn-danger ms-1 open-modal">
            <i class="bi bi-trash"></i> Xóa
        </a>
    }
    else
    {
        <button class="btn btn-secondary ms-1" disabled>
            <i class="bi bi-trash"></i> Không thể xóa
        </button>
    }

    <a href="~/Order" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="alert alert-info mb-3">
    <strong>Trạng thái:</strong> @statusText
</div>

<!-- ================= THÔNG TIN ĐƠN HÀNG ================= -->
<div class="card card-primary card-outline mb-3">
    <div class="card-header">
        <h5><i class="bi bi-receipt"></i> Thông tin đơn hàng</h5>
    </div>
    <div class="card-body">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Mã đơn</div>
            <div class="col-md-3">@Model.OrderID</div>
            <div class="col-md-3 fw-bold">Ngày lập</div>
            <div class="col-md-3">@Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Ngày duyệt</div>
            <div class="col-md-3">@Model.AcceptTime?.ToString("dd/MM/yyyy HH:mm") </div>
            <div class="col-md-3 fw-bold">Ngày hoàn tất</div>
            <div class="col-md-3">@Model.FinishedTime?.ToString("dd/MM/yyyy HH:mm") </div>
        </div>
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Nhân viên xử lý</div>
            <div class="col-md-3">@(!string.IsNullOrWhiteSpace(Model.EmployeeName) ? Model.EmployeeName : "-")</div>

            <div class="col-md-3 fw-bold">Người giao hàng</div>
            <div class="col-md-3">@(!string.IsNullOrWhiteSpace(Model.ShipperName) ? Model.ShipperName : "-")</div>
        </div>
        <div class="row">
            <div class="col-md-3 fw-bold">SĐT người giao</div>
            <div class="col-md-3">@(!string.IsNullOrWhiteSpace(Model.ShipperPhone) ? Model.ShipperPhone : "-")</div>
        </div>
    </div>
</div>

<!-- ================= KHÁCH HÀNG ================= -->
<div class="card card-info card-outline mb-3">
    <div class="card-header">
        <h5><i class="bi bi-person"></i> Khách hàng</h5>
    </div>
    <div class="card-body">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Khách hàng</div>
            <div class="col-md-9">@(!string.IsNullOrWhiteSpace(Model.CustomerName) ? Model.CustomerName : "Khách lẻ")</div>
        </div>
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Địa chỉ</div>
            <div class="col-md-9">@(!string.IsNullOrWhiteSpace(Model.DeliveryAddress) ? Model.DeliveryAddress : "-")</div>
        </div>
        <div class="row">
            <div class="col-md-3 fw-bold">Tỉnh/Thành</div>
            <div class="col-md-9">@(!string.IsNullOrWhiteSpace(Model.DeliveryProvince) ? Model.DeliveryProvince : "-")</div>
        </div>
    </div>
</div>

<!-- ================= DANH SÁCH MẶT HÀNG ================= -->
<div class="card card-secondary card-outline">
    <div class="card-header">
        <h5><i class="bi bi-box"></i> Danh sách mặt hàng</h5>
    </div>
    <div class="card-body table-responsive">
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Tên hàng</th>
                    <th>SL</th>
                    <th class="text-end">Giá</th>
                    <th class="text-end">Thành tiền</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (details != null && details.Count > 0)
                {
                    foreach (var item in details)
                    {
                        var total = item.Quantity * item.SalePrice;
                        sum += total;
                        <tr>
                            <td>@i</td>
                            <td>@item.ProductName</td>
                            <td>@item.Quantity</td>
                            <td class="text-end">@item.SalePrice.ToString("N0")</td>
                            <td class="text-end">@total.ToString("N0")</td>
                            <td>
                                @if (Model.Status == OrderStatusEnum.New || Model.Status == OrderStatusEnum.Accepted)
                                {
                                    <a href="~/Order/EditOrderItem?orderId=@Model.OrderID&productId=@item.ProductID"
                                       class="btn btn-sm btn-primary open-modal">Sửa</a>
                                    <a href="~/Order/DeleteOrderItem?orderId=@Model.OrderID&productId=@item.ProductID"
                                       class="btn btn-sm btn-danger open-modal">Xóa</a>
                                }
                                else
                                {
                                    <span class="text-muted">Không cho phép</span>
                                }
                            </td>
                        </tr>
                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center">Chưa có mặt hàng nào</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="4" class="text-end">Tổng</th>
                    <th class="text-end text-danger">@sum.ToString("N0")</th>
                    <th></th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<!-- ================= MODAL DUYỆT ĐƠN ================= -->
@if (canReject)
{
    <div class="modal fade" id="acceptModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" asp-action="AcceptConfirm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.OrderID" />
                    <div class="modal-header text-bg-primary">
                        <h5 class="modal-title">Xác nhận duyệt đơn hàng</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="alert alert-primary">
                            Bạn có chắc chắn muốn duyệt đơn hàng này?
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary">Chấp nhận</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<!-- ================= MODAL TỪ CHỐI ================= -->
@if (canReject)
{
    <div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" asp-action="Reject">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.OrderID" />
                    <div class="modal-header text-bg-danger">
                        <h5 class="modal-title">Xác nhận từ chối đơn hàng</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="alert alert-danger">
                            Bạn có chắc chắn muốn từ chối đơn hàng này không?
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-danger">Chấp nhận</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<!-- ================= MODAL HỦY ================= -->
@if (canCancel)
{
    <div class="modal fade" id="cancelModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" asp-action="Cancel">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.OrderID" />
                    <div class="modal-header text-bg-warning">
                        <h5 class="modal-title">Xác nhận hủy đơn hàng</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="alert alert-warning">
                            Bạn có chắc chắn muốn hủy đơn hàng này không?
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-warning">Chấp nhận</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<!-- ================= MODAL CHỌN SHIPPER ================= -->
@if (canShip)
{
    <div class="modal fade" id="shippingModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" asp-action="Shipping">
                    @Html.AntiForgeryToken()
                    <div class="modal-header text-bg-info">
                        <h5 class="modal-title">Chọn người giao hàng</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="id" value="@Model.OrderID" />
                        <div class="mb-3">
                            <label class="form-label">Người giao hàng</label>
                            <select name="shipperId" class="form-select" required>
                                <option value="">-- Chọn người giao hàng ---</option>

                                @foreach (var shipper in ViewBag.Shippers)
                                {
                                    <option value="@shipper.ShipperID">
                                        @shipper.ShipperName
                                    </option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-bicycle"></i> Giao hàng
                        </button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<!-- ================= MODAL HOÀN TẤT ================= -->
@if (canFinish)
{
    <div class="modal fade" id="finishModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" asp-action="Finish">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.OrderID" />
                    <div class="modal-header text-bg-success">
                        <h5 class="modal-title">Xác nhận hoàn tất đơn hàng</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="alert alert-success">
                            Bạn có chắc chắn đơn hàng đã giao thành công?
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-success">Chấp nhận</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}