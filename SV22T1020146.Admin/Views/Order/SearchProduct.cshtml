@model PagedResult<Product>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Có <strong>@Model.RowCount</strong> mặt hàng
</div>

@foreach (var item in Model.DataItems)
{
    <form method="post" action="~/Order/AddToCart" class="border rounded p-2 mb-2">

        <strong>@item.ProductName</strong>

        <div class="row mt-2">
            <div class="col-4">
                <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "no-image.png" : item.Photo)"
                     class="img-fluid border" style="max-height:100px" />
            </div>

            <div class="col-8">
                <div class="row g-2">

                    <div class="col-7">
                        <label>Giá</label>
                        <input class="form-control form-control-sm"
                               name="salePrice"
                               value="@item.Price" />
                    </div>

                    <div class="col-5">
                        <label>SL</label>
                        <input type="number"
                               name="Quantity"   
                               value="1"
                               min="1"
                               class="form-control form-control-sm" />
                    </div>

                </div>

                <input type="hidden" name="productId" value="@item.ProductID" />

                <button class="btn btn-sm btn-primary mt-2 w-100">
                    <i class="bi bi-cart-plus"></i> Thêm vào giỏ
                </button>
            </div>
        </div>
    </form>
}
<div class="card-footer">
    <ul class="pagination justify-content-center mb-0">

        @{
            int currentPage = Model.Page;
            int totalPages = Model.PageCount;

            int start = Math.Max(1, currentPage - 2);
            int end = Math.Min(totalPages, currentPage + 2);
        }

        <!-- Trang đầu -->
        @if (start > 1)
        {
            <li class="page-item">
                <a class="page-link"
                   href="javascript:;"
                   onclick="paginationSearch(event, document.getElementById('formSearchProduct'), 1)">
                    1
                </a>
            </li>

            @if (start > 2)
            {
                <li class="page-item disabled">
                    <a class="page-link">...</a>
                </li>
            }
        }

        <!-- Các trang giữa -->
        @for (int i = start; i <= end; i++)
        {
            if (i == currentPage)
            {
                <li class="page-item active">
                    <a class="page-link">@i</a>
                </li>
            }
            else
            {
                <li class="page-item">
                    <a class="page-link"
                       href="javascript:;"
                       onclick="paginationSearch(event, document.getElementById('formSearchProduct'), @i)">
                        @i
                    </a>
                </li>
            }
        }

        <!-- Trang cuối -->
        @if (end < totalPages)
        {
            if (end < totalPages - 1)
            {
                <li class="page-item disabled">
                    <a class="page-link">...</a>
                </li>
            }

            <li class="page-item">
                <a class="page-link"
                   href="javascript:;"
                   onclick="paginationSearch(event, document.getElementById('formSearchProduct'), @totalPages)">
                    @totalPages
                </a>
            </li>
        }

    </ul>
</div>