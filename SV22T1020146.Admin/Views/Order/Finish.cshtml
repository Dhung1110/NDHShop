@model SV22T1020146.Models.Sales.OrderViewInfo

<!-- Modal Hoàn tất đơn hàng -->
<div class="modal fade" id="finishOrderModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" action="~/Order/Finish/@Model.OrderID">
                @Html.AntiForgeryToken()
                <div class="modal-header text-bg-success">
                    <h5 class="modal-title">Xác nhận hoàn tất đơn hàng</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-success mb-0">
                        Bạn có chắc chắn đơn hàng đã giao thành công?
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Chấp nhận</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Bootstrap JS (bundle với Popper) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>