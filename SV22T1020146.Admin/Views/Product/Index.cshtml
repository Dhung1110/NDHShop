@model ProductSearchInput

@{
    ViewBag.Title = "Quản lý Mặt hàng";
}

@section PageToolBar {
    <a href="~/Product/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">

        <form id="formSearch"
              method="get"
              action="~/Product/Search"
              data-target="searchResult"
              onsubmit="paginationSearch(event, this, 1)">

            <div class="row g-2">

                <input type="hidden" asp-for="PageSize" />

                <div class="col-md-3">

                    <label>Loại hàng</label>

                    <select name="CategoryID" class="form-select">

                        <option value="0">-- Tất cả --</option>

                        @foreach (var item in ViewBag.Categories)
                        {
                            if (item.CategoryID == Model.CategoryID)
                            {
                                <option value="@item.CategoryID" selected>@item.CategoryName</option>
                            }
                            else
                            {
                                <option value="@item.CategoryID">@item.CategoryName</option>
                            }
                        }

                    </select>

                </div>

                <div class="col-md-3">

                    <label>Nhà cung cấp</label>

                    <select name="SupplierID" class="form-select">

                        <option value="0">-- Tất cả --</option>

                        @foreach (var item in ViewBag.Suppliers)
                        {
                            if (item.SupplierID == Model.SupplierID)
                            {
                                <option value="@item.SupplierID" selected>@item.SupplierName</option>
                            }
                            else
                            {
                                <option value="@item.SupplierID">@item.SupplierName</option>
                            }
                        }

                    </select>

                </div>

                <div class="col-md-3">

                    <label>Khoảng giá</label>

                    <div class="input-group">

                        <input type="text"
                               name="MinPrice"
                               value="@Model.MinPrice"
                               class="form-control"
                               placeholder="Từ" />

                        <span class="input-group-text">-</span>

                        <input type="text"
                               name="MaxPrice"
                               value="@Model.MaxPrice"
                               class="form-control"
                               placeholder="Đến" />

                    </div>

                </div>

                <div class="col-md-3">

                    <label>Tên mặt hàng</label>

                    <div class="input-group">

                        <input type="text"
                               name="SearchValue"
                               value="@Model.SearchValue"
                               class="form-control"
                               placeholder="Tên mặt hàng..." />

                        <button class="btn btn-info">
                            <i class="bi bi-search"></i>
                        </button>

                    </div>

                </div>

            </div>

        </form>

    </div>
</div>

<div id="searchResult"></div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
    });
</script>