@model Product
@{
    ViewBag.Title = "Xác nhận xóa mặt hàng";
    bool isUsed = ViewBag.IsUsed ?? false;
}

@section PageToolBar {
    <div class="d-flex">
        @if (!isUsed)
        {
           
            <form action="~/Product/DeleteConfirm/@Model.ProductID" method="post"
                  onsubmit="return confirm('Bạn có chắc chắn muốn xóa mặt hàng này không?')">
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash me-1"></i> Xác nhận xóa
                </button>
            </form>
        }

        <a href="~/Product" class="btn btn-secondary ms-2">
            <i class="bi bi-arrow-left"></i> Quay lại 
        </a>
    </div>
}

<div class="row">
    <div class="col-12">
        @if (isUsed)
        {
            <div class="alert alert-danger">
                Loại hàng này đang được sử dụng. Không thể xóa!
            </div>
        }
        else
        {
            <div class="alert alert-warning d-flex align-items-center">
                <i class="bi bi-info-circle me-2"></i>
                Bạn có chắc chắn muốn xóa loại hàng sau không?
            </div>
        }

       
        <div class="card card-outline @(isUsed ? "card-secondary" : "card-danger")">
            <div class="card-header">
                <h3 class="card-title">Thông tin mặt hàng</h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-8">
                        <dl class="row">
                            <dt class="col-sm-4">Tên mặt hàng:</dt>
                            <dd class="col-sm-8 text-primary fw-bold">@Model.ProductName</dd>

                            <dt class="col-sm-4">Đơn vị tính:</dt>
                            <dd class="col-sm-8">@Model.Unit</dd>

                            <dt class="col-sm-4">Giá bán:</dt>
                            <dd class="col-sm-8">@Model.Price.ToString("N0") VNĐ</dd>
                        </dl>
                    </div>
                    <div class="col-md-4 text-center">
                        <img src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                             class="img-thumbnail" style="max-height:150px" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>